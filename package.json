{
  "name": "recruitai-tooling",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Tooling for RecruitAI (Linting, Coverage, etc.)",
  "scripts": {
    "lint:js": "npx --yes eslint web/assets/js",
    "lint:css": "npx --yes stylelint \"web/assets/css/**/*.css\"",
    "knip": "npx --yes knip --config tooling/knip.json",
    "purgecss": "npx --yes purgecss --css web/assets/css/**/*.css --content web/index.html web/assets/js/**/*.js --output web/assets/css/dist"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "stylelint": "^16.0.0",
    "knip": "^5.0.0",
    "purgecss": "^8.0.0"
  }
}
