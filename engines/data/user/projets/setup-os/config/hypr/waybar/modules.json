{
  "custom/nixos": {
    "format": "´îô",
    "on-click": "wofi --show drun",
    "tooltip": true,
    "tooltip-format": "NixOS"
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip": true,
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "waybar"
    ],
    "app_ids-mapping": {
      "firefox": "firefox",
      "org.gnome.Nautilus": "org.gnome.Nautilus"
    }
  },
  "custom/cava_mviz": {
    "exec": "$HOME/.config/waybar/WaybarCava.sh",
    "format": "{}"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "active-only": false,
    "format": "{icon}",
    "on-click": "hyprctl dispatch workspace {id}",
    "format-icons": {
      "1": "´äî",
      "2": "´äî",
      "3": "´äî",
      "4": "´äî",
      "5": "´äî",
      "urgent": "´ü¬",
      "active": "´äæ",
      "default": "´äî"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "cpu": {
    "format": "´ïø  {usage}%",
    "tooltip": true,
    "on-click": "kitty htop &"
  },
  "memory": {
    "format": "´âë  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "´ïç {temperatureC}",
    "format": "´ïë {temperatureC}┬░C"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "´ùº  {capacity}%",
    "format-plugged": "´çª  {capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "´Ü®",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ûÉ",
      "headset": "´ûÉ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": [
        "´Çª",
        "´Çº",
        "´Ç¿"
      ]
    },
    "on-click": "pavucontrol"
  },
  "network#speed": {
    "interval": 1,
    "format-wifi": "  ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
    "format-ethernet": "  ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
    "format-disconnected": "",
    "tooltip-format": "{ipaddr}",
    "min-length": 24,
    "max-length": 24
  },
  "bluetooth": {
    "format": "´èô",
    "format-disabled": "",
    "format-connected": " {num_connections}",
    "tooltip": true
  },
  "tray": {
    "icon-size": 20,
    "spacing": 6
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },
  "mpris": {
    "interval": 10,
    "format": "{player_icon}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "player-icons": {
      "chromium": "´ë¿",
      "default": "´ÇØ",
      "firefox": "´ë®",
      "spotify": "´å╝",
      "vlc": ""
    },
    "status-icons": {
      "paused": "",
      "playing": "´üï",
      "stopped": "´üì"
    },
    "max-length": 30
  }
}