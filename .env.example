# Copie ce fichier vers .env et remplis les valeurs.
# `nix develop` exporte déjà DATABASE_URL avec la valeur par défaut ci-dessous.

DATABASE_URL=postgresql:///alternance?host=./.pg&user=alternance

# Phase 2 — clés API LLM
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
VOYAGE_API_KEY=

# Optionnel
BIND=127.0.0.1:8000
WEB_DIR=web
RUST_LOG=info,sqlx=warn,hyper=warn,tower_http=info

# Optional: Local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional: Scraping fallback (Cloudflare / anti-bot)
SCRAPINGANT_API_KEY=
SCRAPINGANT_ENDPOINT=https://api.scrapingant.com/v2/general
SCRAPINGANT_TIMEOUT_SECS=45
SCRAPINGANT_BROWSER=true
SCRAPINGANT_PROXY_TYPE=
SCRAPINGANT_PROXY_COUNTRY=

# Optional: Generation queue hardening
GEN_QUEUE_CONCURRENCY=2
GEN_QUEUE_MAX_PENDING=8

# Optional: Ingestion parallelism hardening
INGEST_MAX_PARALLEL=2
INGEST_PER_HOST_MAX_PARALLEL=1
